<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.dao.UserRoleDao">

    <select id="getUserRoleByUserId" parameterType="java.lang.Long" resultType="org.example.model.UserRole">
        select
            ur.*,
            ar.name roleName,
            ar.code roleCode
        from
            user_role ur
                left join auth_role ar on ur.roleId = ar.id
        where
            ur.userId = #{userId}
    </select>
</mapper>