# Development environment configuration example
# Copy this file to application-dev.yml and configure your own settings

# port
server:
  port: 8089

# datasource
spring:
  datasource:
    url: jdbc:mysql://${DB_HOST:localhost}:3306/${DB_NAME:mydb_dev}?useSSL=false&serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf-8&allowPublicKeyRetrieval=true
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:your_password_here}
    driver-class-name: com.mysql.cj.jdbc.Driver

  # redis
  redis:
    host: ${REDIS_HOST:localhost}
    port: ${REDIS_PORT:6379}
    password: ${REDIS_PASSWORD:your_password_here}
    connect-timeout: 100

  # multipart
  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 100MB

# rocketmq
rocketmq:
  name-server: ${ROCKETMQ_NAMESERVER:localhost:9876}
  producer:
    group: springboot_producer_group

# fastdfs
fdfs:
  connect-timeout: 6000
  so-timeout: 6000
  tracker-list: ${FASTDFS_TRACKER:localhost:22122}
  http:
    storage-addr: ${FASTDFS_STORAGE:http://localhost:8888/group1/}

# elasticsearch
elasticsearch:
  url: ${ES_URL:localhost:9200}

# log
log:
  level: DEBUG

# eureka
eureka:
  instance:
    instanceId: ${spring.cloud.client.ip-address}:${server.port}
    prefer-ip-address: true
    lease-renewal-interval-in-seconds: 2
    lease-expiration-duration-in-seconds: 10
  client:
    service-url:
      defaultZone: ${EUREKA_URL:http://localhost:8761/eureka/}

spring.application.name: my-multi-module-project
